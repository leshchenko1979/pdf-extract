{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Sync compose and env to VDS",
            "type": "shell",
            "command": "bash",
            "args": [
                "${workspaceFolder}/scripts/sync-vds-service.sh"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "showReuseMessage": false
            },
            "problemMatcher": []
        },
        {
            "label": "Run Go tests",
            "type": "shell",
            "command": "go",
            "args": [
                "test",
                "./...",
                "-count=1"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "showReuseMessage": false
            },
            "problemMatcher": []
        },
        {
            "label": "Manual deploy (deploy.sh)",
            "type": "shell",
            "command": "bash",
            "args": [
                "${workspaceFolder}/deploy.sh"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "showReuseMessage": false
            },
            "problemMatcher": []
        },
        {
            "label": "SSH to remote (deploy.sh hosts)",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "set -a && source .env && set +a && ssh \"$REMOTE_USER@$REMOTE_HOST_IP\""
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "showReuseMessage": false
            },
            "problemMatcher": []
        },
        {
            "label": "Test process URL (text only)",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "set -a && source .env && set +a && curl -sS -X POST \"${PUBLIC_BASE_URL}/v1/process\" -H \"Content-Type: application/json\" -d '{\"source\":{\"type\":\"url\",\"url\":\"${input:pdfUrl}\"},\"options\":{\"render_image\":false}}'"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "showReuseMessage": false
            },
            "problemMatcher": []
        },
        {
            "label": "Test process URL (with PNG)",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "set -a && source .env && set +a && curl -sS -X POST \"${PUBLIC_BASE_URL}/v1/process\" -H \"Content-Type: application/json\" -d '{\"source\":{\"type\":\"url\",\"url\":\"${input:pdfUrl}\"},\"options\":{\"render_image\":true,\"crop_margins\":true}}'"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "showReuseMessage": false
            },
            "problemMatcher": []
        },
        {
            "label": "Debug process URL (verbose)",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "set -a && source .env && set +a && curl -sS -v -X POST \"${PUBLIC_BASE_URL}/v1/process\" -H \"Content-Type: application/json\" -d '{\"source\":{\"type\":\"url\",\"url\":\"${input:pdfUrl}\"},\"options\":{\"render_image\":false}}'"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "showReuseMessage": false
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "pdfUrl",
            "type": "promptString",
            "description": "Public URL of the PDF for POST /v1/process"
        }
    ]
}