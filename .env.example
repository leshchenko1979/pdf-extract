# Required: public origin for image URLs in API responses (no trailing slash).
# Local: http://localhost:8000 — behind HTTPS: https://your-domain.example
PUBLIC_BASE_URL=http://localhost:8000

# Optional — scripts/sync-vds-service.sh: SSH to the VDS (same idea as ai-gateway)
# SSH_HOST=203.0.113.10
# SSH_USER=root
# SSH_KEY=/path/to/id_ed25519
# SSH_PORT=22
# REMOTE_DOCKER_DIR=/root/services/pdf-extract
# Optional: pull private GHCR images on the server (same values as GitHub Actions secrets)
# GHCR_PULL_USER=github-username
# GHCR_PULL_TOKEN=ghp_...

# Optional — only for emergency deploy.sh (tarball + remote build)
# REMOTE_USER=deploy
# REMOTE_HOST_IP=203.0.113.10
